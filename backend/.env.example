# Entorno de Base de Datos (Elasticsearch)
# Cambiar por la URL y la API Key de tu clúster de Elastic Cloud en producción.
ELASTICSEARCH_URL=https://my-elasticsearch-project-xxxxxx.es.us-central1.gcp.elastic.cloud:443
ELASTIC_URL=https://my-elasticsearch-project-xxxxxx.es.us-central1.gcp.elastic.cloud:443
ELASTIC_API_KEY=tu_api_key_aqui
ELASTIC_ENDPOINT=https://my-elasticsearch-project-xxxxxx.es.us-central1.gcp.elastic.cloud:443

# Configuración de Servidor
PUBLIC_SERVER_URL=http://localhost:8080

# Twilio (Opcional - Si no se provee, el sistema operará automáticamente en Modo Simulación imprimiendo en consola)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=+14155238886

# Email / Resend API Key (Opcional - Si no se provee, guardará los correos como archivos HTML estáticos para previsualización)
RESEND_API_KEY=
