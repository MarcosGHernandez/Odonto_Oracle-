# Entorno de Base de Datos (Elasticsearch)
# Para desarrollo local (Docker) usamos http://localhost:9200 sin API Key
# Para producción, cambia a la URL de Elastic Cloud y añade la API Key
ELASTICSEARCH_URL=http://127.0.0.1:9200
ELASTIC_URL=http://127.0.0.1:9200
ELASTIC_API_KEY=

# Otras APIs (Twilio, Gmail, etc. se añadirán en el Sprint 2)
PUBLIC_SERVER_URL=http://localhost:8000
