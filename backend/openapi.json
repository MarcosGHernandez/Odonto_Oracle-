{
  "openapi": "3.1.0",
  "info": {
    "title": "Odonto-Oracle Backend API",
    "description": "Backend modular y altamente estructurado para el Agente Clínico y herramientas de soporte odontológico.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Public URL"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Health check del sistema",
        "description": "Verifica que el backend de Odonto-Oracle está operativo y retorna la versión actual.",
        "operationId": "health_check_root",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/settings": {
      "get": {
        "summary": "Obtener ajustes de la clínica",
        "description": "Retorna el perfil del consultorio y los números emisores de WhatsApp/SMS configurados.",
        "operationId": "obtener_settings",
        "parameters": [
          {
            "name": "clinica_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "OO-CLINIC-001",
              "title": "Clinica Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Actualizar ajustes de la clínica",
        "description": "Guarda el perfil del consultorio y los números emisores de WhatsApp/SMS en el almacenamiento persistente.",
        "operationId": "guardar_settings",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SettingsPayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/clinica/metricas": {
      "get": {
        "summary": "Obtener métricas de la clínica en tiempo real",
        "description": "Calcula estadísticas dinámicas leyendo la base de datos de pacientes filtrada por clinica_id.",
        "operationId": "obtener_metricas_clinica",
        "parameters": [
          {
            "name": "clinica_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "OO-CLINIC-001",
              "title": "Clinica Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/clinica/agenda/{clinica_id}": {
      "get": {
        "summary": "Obtener agenda completa de la clínica",
        "description": "Devuelve todas las citas de la clínica. Intenta consultar Elasticsearch y cae en JSON local si no está activo.",
        "operationId": "obtener_agenda",
        "parameters": [
          {
            "name": "clinica_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Clinica Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Verificar salud de la API",
        "description": "Retorna el estado operativo de los servicios del backend de Odonto-Oracle.",
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/test/read_db": {
      "get": {
        "summary": "Endpoint temporal para verificar base de datos local JSON",
        "description": "Devuelve el estado crudo completo de la base de datos local JSON de citas, pacientes y precios.",
        "operationId": "test_read_db",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/webhook/paciente": {
      "post": {
        "summary": "Registrar o actualizar paciente",
        "description": "Registra un nuevo paciente o actualiza su información clínica (antecedentes, alergias, vitales) en Elasticsearch y base local JSON. Este endpoint debe ser invocado por el agente en la nube o la interfaz de usuario cuando se requiera realizar el onboarding de un paciente o actualizar su ficha médica con nuevos signos vitales o antecedentes clínicos. Devuelve un JSON estructurado.",
        "operationId": "registrar_paciente",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PacientePayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pacientes/{clinica_id}": {
      "get": {
        "summary": "Listar todos los pacientes de la clínica",
        "description": "Devuelve todos los pacientes registrados bajo un clinica_id específico. Requerido por la tabla del dashboard de React para carga inicial.",
        "operationId": "listar_pacientes",
        "parameters": [
          {
            "name": "clinica_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Clinica Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pacientes/{clinica_id}/{paciente_id}": {
      "get": {
        "summary": "Obtener expediente de un paciente específico",
        "description": "Devuelve el expediente clínico detallado y actualizado de un paciente específico (antecedentes, alergias, vitales, historial de documentos).",
        "operationId": "obtener_paciente",
        "parameters": [
          {
            "name": "clinica_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Clinica Id"
            }
          },
          {
            "name": "paciente_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Paciente Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tools/search_patient": {
      "post": {
        "summary": "Buscar expediente de paciente",
        "description": "Busca un paciente en el directorio de Elasticsearch de la clínica actual por su nombre o apellidos. Retorna sus datos personales, historial clínico, medicamentos, alergias y signos vitales. El agente LLM DEBE invocar esta herramienta obligatoriamente antes de generar una receta, plan de tratamiento o presupuesto para comprobar que el paciente existe y obtener sus datos correctos. No inventar nunca datos del paciente.",
        "operationId": "buscar_paciente",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchPatientPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tools/schedule_appointment": {
      "post": {
        "summary": "Agendar cita o consulta dental",
        "description": "Registra una nueva cita odontológica en Elasticsearch (índice consultas_produccion) y base de datos local JSON. Retorna confirmación del agendamiento. El agente LLM debe invocar este endpoint cuando el doctor indique explícitamente programar o agendar una cita para un paciente.",
        "operationId": "agendar_cita",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScheduleAppointmentPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tools/modify_appointment": {
      "post": {
        "summary": "Modificar cita o consulta dental",
        "description": "Actualiza campos específicos de una cita odontológica existente en Elasticsearch y base de datos local JSON.",
        "operationId": "modificar_cita",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ModifyAppointmentPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tools/cancel_appointment": {
      "post": {
        "summary": "Cancelar cita o consulta dental",
        "description": "Elimina una cita de la base de datos local JSON y Elasticsearch.",
        "operationId": "cancelar_cita",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelAppointmentPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tools/complete_appointment": {
      "post": {
        "summary": "Marcar cita como completada o consultada",
        "description": "Actualiza el estado de una cita odontológica a 'completada' en Elasticsearch y base de datos local JSON.",
        "operationId": "completar_cita",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompleteAppointmentPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tools/delete_patient": {
      "post": {
        "summary": "Eliminar paciente y expediente clínico",
        "description": "Elimina un paciente, su expediente y todas sus citas de la base local JSON y Elasticsearch.",
        "operationId": "eliminar_paciente",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeletePacientePayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tools/search_paciente": {
      "get": {
        "summary": "Buscar expediente de paciente (GET legado)",
        "description": "Endpoint GET heredado para buscar pacientes. Mantenido por compatibilidad.",
        "operationId": "buscar_paciente_legacy",
        "parameters": [
          {
            "name": "clinica_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Clinica Id"
            }
          },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Query"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tools/scraper": {
      "post": {
        "summary": "Escanear precios de mercado de materiales",
        "description": "Realiza web scraping en tiempo real en depósitos dentales de la región especificada ('MX' o 'US') para buscar el precio comparativo de un insumo o material dental. Guarda el registro en el histórico y devuelve un JSON con productos, precios y enlaces. El agente LLM debe invocar este endpoint cuando el doctor solicite cotizar o buscar precios de un material dental.",
        "operationId": "buscar_precios_material",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScraperPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tools/pdf_generator": {
      "post": {
        "summary": "Generar documento clínico en PDF",
        "description": "Genera un archivo PDF físico elegante y profesional (receta médica, presupuesto dental formal o plan de tratamiento) con los datos del paciente e información detallada. Guarda el archivo en un directorio estático público y devuelve su URL de descarga. El agente LLM debe llamar a esta herramienta una vez haya recopilado la información del paciente y los precios para consolidar el archivo y presentárselo al doctor.",
        "operationId": "generar_documento_clinico",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PDFPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tools/notifier": {
      "post": {
        "summary": "Enviar notificación al paciente",
        "description": "Envía una notificación o mensaje en tiempo real a un paciente (simulado o real con Twilio) mediante WhatsApp o SMS. El agente LLM debe usar esta herramienta cuando el doctor solicite expresamente enviar una alerta, un presupuesto o una receta directo al celular del paciente.",
        "operationId": "enviar_notificacion_paciente",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NotifierPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CancelAppointmentPayload": {
        "properties": {
          "clinica_id": {
            "type": "string",
            "title": "Clinica Id",
            "description": "Identificador único de la clínica.",
            "default": "OO-CLINIC-001"
          },
          "appointment_id": {
            "type": "string",
            "title": "Appointment Id",
            "description": "ID de la cita a cancelar."
          }
        },
        "type": "object",
        "required": [
          "appointment_id"
        ],
        "title": "CancelAppointmentPayload"
      },
      "CompleteAppointmentPayload": {
        "properties": {
          "clinica_id": {
            "type": "string",
            "title": "Clinica Id",
            "description": "Identificador único de la clínica.",
            "default": "OO-CLINIC-001"
          },
          "appointment_id": {
            "type": "string",
            "title": "Appointment Id",
            "description": "ID de la cita a marcar como completada."
          },
          "diagnostico": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Diagnostico",
            "description": "Diagnóstico final clínico."
          },
          "tratamiento": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tratamiento",
            "description": "Tratamiento realizado."
          },
          "notas_adicionales": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notas Adicionales",
            "description": "Notas clínicas adicionales."
          }
        },
        "type": "object",
        "required": [
          "appointment_id"
        ],
        "title": "CompleteAppointmentPayload"
      },
      "DeletePacientePayload": {
        "properties": {
          "clinica_id": {
            "type": "string",
            "title": "Clinica Id",
            "description": "ID de la clínica (tenant) para aislar la eliminación."
          },
          "paciente_id": {
            "type": "string",
            "title": "Paciente Id",
            "description": "ID del paciente a eliminar."
          }
        },
        "type": "object",
        "required": [
          "clinica_id",
          "paciente_id"
        ],
        "title": "DeletePacientePayload"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ModifyAppointmentPayload": {
        "properties": {
          "clinica_id": {
            "type": "string",
            "title": "Clinica Id",
            "description": "Identificador único de la clínica.",
            "default": "OO-CLINIC-001"
          },
          "appointment_id": {
            "type": "string",
            "title": "Appointment Id",
            "description": "ID de la cita a modificar (ej. 'C-...')."
          },
          "fecha_consulta": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Fecha Consulta",
            "description": "Nueva fecha y hora de la cita."
          },
          "diagnostico": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Diagnostico",
            "description": "Nuevo diagnóstico o motivo."
          },
          "tratamiento": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tratamiento",
            "description": "Nuevo tratamiento."
          },
          "notas_adicionales": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notas Adicionales",
            "description": "Nuevas notas clínicas."
          }
        },
        "type": "object",
        "required": [
          "appointment_id"
        ],
        "title": "ModifyAppointmentPayload"
      },
      "NotifierPayload": {
        "properties": {
          "paciente_id": {
            "type": "string",
            "title": "Paciente Id",
            "description": "Número de teléfono móvil o identificador de destino del paciente (ej. '+529511234567')."
          },
          "mensaje_texto": {
            "type": "string",
            "title": "Mensaje Texto",
            "description": "Texto redactado en lenguaje natural que se enviará al celular del paciente."
          },
          "canal": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Canal",
            "description": "Canal de comunicación a utilizar para la entrega: 'whatsapp' (predeterminado) o 'sms'.",
